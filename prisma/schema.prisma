// ExamFlow Pro - Complete Prisma Schema
// MongoDB-compatible, production-ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  TEACHER
  STUDENT
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  RESULT_PUBLISHED
}

enum Phase8CalendarStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Phase8ScheduleSessionType {
  REGULAR
  MIDTERM
  FINAL
  SUPPLEMENTARY
  IMPROVEMENT
  BACKLOG
  RETAKE
  PRACTICAL
  LAB
}

