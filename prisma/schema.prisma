  isActive             Boolean                 @default(true)
  notes                String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  student                    StudentProfile              @relation(fields: [studentId], references: [id])
  department                 Department                  @relation(fields: [departmentId], references: [id])
  academicYear               AcademicYear?               @relation(fields: [academicYearId], references: [id])
  academicSession            AcademicSession             @relation(fields: [academicSessionId], references: [id])
  program                    AcademicProgram             @relation(fields: [programId], references: [id])
  programYear                ProgramYear                 @relation(fields: [programYearId], references: [id])
  semester                   Semester                    @relation(fields: [semesterId], references: [id])
  programSemester            ProgramSemester?            @relation(fields: [programSemesterId], references: [id])
  group                      Group                       @relation(fields: [groupId], references: [id])
  departmentLanguage         DepartmentLanguage?         @relation(fields: [departmentLanguageId], references: [id])
  language                   Language?                   @relation(fields: [languageId], references: [id])
