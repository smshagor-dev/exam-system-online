  GRADUATED
  DROPPED
  ALUMNI
}

enum StudentAcademicHistoryEventType {
  ADMISSION
  ENROLLMENT
  PROMOTION
  GROUP_TRANSFER
  DEPARTMENT_TRANSFER
  PROGRAM_TRANSFER
  ACADEMIC_LEAVE
  READMISSION
  GRADUATION
  ALUMNI
  STATUS_CHANGE
  LEGACY_SYNC
  MANUAL_CORRECTION
}

enum StudentPromotionStatus {
  PROMOTED
  BLOCKED
  OVERRIDDEN
}

enum StudentTransferType {
  GROUP
  DEPARTMENT
  PROGRAM
}

enum StudentLeaveType {
  MEDICAL
  ACADEMIC
  TEMPORARY
  OTHER
}

enum TeachingAssignmentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
  REJECTED
}

enum TeachingAssignmentRoleType {
  LEAD_TEACHER
  ASSISTANT_TEACHER
  LECTURER
  LAB_INSTRUCTOR
  EXAMINER
  REVIEWER
  MODERATOR
  COURSE_COORDINATOR
  GUEST_TEACHER
  SUBSTITUTE
}

enum TeacherWorkloadCategory {
  LECTURE
  LAB
  PRACTICAL
  CONSULTATION
  ASSESSMENT
  EXAM_SUPERVISION
  PROJECT_SUPERVISION
  RESEARCH
  ADMINISTRATION
  OTHER
}

enum TeacherSubstitutionStatus {
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

model User {
  id                         String    @id @default(cuid()) @map("_id")
  email                      String    @unique
  password                   String
  name                       String
  role                       UserRole  @default(STUDENT)
  isActive                   Boolean   @default(true)
  isEmailVerified            Boolean   @default(true)
  emailVerificationCode      String?
  emailVerificationExpiresAt DateTime?
  passwordResetCode          String?
  passwordResetExpiresAt     DateTime?
  avatarUrl                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  teacherProfile              TeacherProfile?
  studentProfile              StudentProfile?
  notifications               Notification[]
  activityLogs                ActivityLog[]
  examAttendanceMarks         ExamAttendanceRecord[]       @relation("ExamAttendanceMarker")
  examIncidentReports         ExamIncident[]               @relation("ExamIncidentReporter")
  examIncidentAcknowledges    ExamIncident[]               @relation("ExamIncidentAcknowledger")
  departmentAdminOf           Department[]                 @relation("DepartmentAdmin")
  resultReviews               ResultReview[]
  academicHistoryActions      StudentAcademicHistory[]
  approvedTeachingAssignments TeachingAssignment[]         @relation("TeachingAssignmentApprover")
  assignmentApprovals         TeachingAssignmentApproval[] @relation("TeachingAssignmentApprovalActor")
  substitutionApprovals       TeacherSubstitution[]        @relation("TeacherSubstitutionApprover")
  workloadApprovals           TeacherWorkloadEntry[]       @relation("TeacherWorkloadApprover")
  teacherAssignmentLogs       TeacherAssignmentAuditLog[]
  phase9GradeEntriesEntered   Phase9GradeEntry[]           @relation("Phase9GradeEntryEnteredBy")
  phase9GradeEntriesVerified  Phase9GradeEntry[]           @relation("Phase9GradeEntryVerifiedBy")
  phase9ResultTransitions     Phase9ResultTransition[]
  phase9TranscriptsGenerated  Phase9TranscriptRecord[]     @relation("Phase9TranscriptGeneratedBy")
  phase9MarksheetsGenerated   Phase9MarksheetRecord[]      @relation("Phase9MarksheetGeneratedBy")
  phase9CertificatesIssued    Phase9CertificateRecord[]    @relation("Phase9CertificateIssuedBy")
  phase9AppealsReviewed       Phase9ResultAppeal[]         @relation("Phase9AppealReviewedBy")
  phase9GraduationsApproved   Phase9GraduationCandidate[]  @relation("Phase9GraduationApprovedBy")
  phase9GraduationsCertified  Phase9GraduationCandidate[]  @relation("Phase9GraduationCertifiedBy")

  @@index([role])
  @@map("users")
}

model Department {
  id          String   @id @default(cuid()) @map("_id")
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  adminId     String?

  admin                      User?                         @relation("DepartmentAdmin", fields: [adminId], references: [id])
  subjects                   Subject[]
  teachers                   TeacherProfile[]
  students                   StudentProfile[]
  academicPrograms           AcademicProgram[]
  departmentLanguages        DepartmentLanguage[]
  academicGroups             Group[]                       @relation("AcademicGroupDepartment")
  academicOfferings          AcademicOffering[]
  examCalendars              ExamAcademicCalendar[]
  examHolidays               ExamCalendarHoliday[]
  examCampuses               ExamCampus[]
  examScheduleSessions       ExamSchedulingSession[]
  examScheduleItems          ExamScheduleItem[]
  examDutyAssignments        ExamDutyAssignment[]
  exams                      Exam[]
  teacherAssignments         TeacherAssignment[]
  registrationFields         RegistrationField[]
  ebookUploads               EbookUpload[]
  courseworkRules            CourseworkRule[]
  courseworkAssignments      CourseworkAssignment[]
  courseworkTemplates        CourseworkTemplate[]
  courseworkPublications     CourseworkPublication[]
  enrollments                StudentEnrollment[]
  historyFromRecords         StudentAcademicHistory[]      @relation("HistoryFromDepartment")
  historyToRecords           StudentAcademicHistory[]      @relation("HistoryToDepartment")
  transferFromRecords        StudentTransfer[]             @relation("TransferFromDepartment")
  transferToRecords          StudentTransfer[]             @relation("TransferToDepartment")
  teacherMemberships         TeacherDepartmentMembership[]
  teachingAssignments        TeachingAssignment[]
  workloadPolicies           TeacherWorkloadPolicy[]
  phase9GradingScales        Phase9GradingScale[]
  phase9ResultPolicies       Phase9ResultPolicy[]
  phase9OfficerAssignments   Phase9OfficerAssignment[]
  phase9Gradebooks           Phase9Gradebook[]
  phase9ResultRecords        Phase9ResultRecord[]
  phase9DegreeAudits         Phase9DegreeAudit[]
  phase9TranscriptRecords    Phase9TranscriptRecord[]
  phase9MarksheetRecords     Phase9MarksheetRecord[]
  phase9CertificateRecords   Phase9CertificateRecord[]
  phase9ResultAppeals        Phase9ResultAppeal[]
  phase9GraduationCandidates Phase9GraduationCandidate[]
  phase10Courses             Phase10Course[]

  @@map("departments")
}

model Subject {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  code         String   @unique
  description  String?
  departmentId String
  languageId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department                 Department                  @relation(fields: [departmentId], references: [id])
  language                   Language?                   @relation(fields: [languageId], references: [id])
  programSubjects            ProgramSubject[]
  academicOfferings          AcademicOffering[]
  teacherAssignments         TeacherAssignment[]
  studentSubjects            StudentSubject[]
  exams                      Exam[]
  examScheduleItems          ExamScheduleItem[]
  questions                  Question[]
  ebookUploads               EbookUpload[]
  courseworkRules            CourseworkRule[]
  courseworkAssignments      CourseworkAssignment[]
  courseworkTemplates        CourseworkTemplate[]
  courseworkPublications     CourseworkPublication[]
  phase10Courses             Phase10Course[]
  phase10CoursePrerequisites Phase10CoursePrerequisite[]

  @@index([departmentId])
  @@index([languageId])
  @@map("subjects")
}

model Language {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects                         Subject[]
  departmentLanguages              DepartmentLanguage[]
  academicGroups                   Group[]                            @relation("AcademicGroupLanguage")
  academicOfferings                AcademicOffering[]
  teacherAssignments               TeacherAssignment[]
  studentSubjects                  StudentSubject[]
  exams                            Exam[]
  examScheduleItems                ExamScheduleItem[]
  questions                        Question[]
  ebookUploads                     EbookUpload[]
  courseworkRules                  CourseworkRule[]
  courseworkAssignments            CourseworkAssignment[]
  courseworkTemplates              CourseworkTemplate[]
  courseworkPublications           CourseworkPublication[]
  enrollments                      StudentEnrollment[]
  examTranslations                 ExamTranslation[]                  @relation("ExamTranslationLanguage")
  questionTranslations             QuestionTranslation[]              @relation("QuestionTranslationLanguage")
  questionOptionTranslations       QuestionOptionTranslation[]        @relation("QuestionOptionTranslationLanguage")
  courseworkRuleTranslations       CourseworkRuleTranslation[]        @relation("CourseworkRuleTranslationLanguage")
  courseworkAssignmentTranslations CourseworkAssignmentTranslation[]  @relation("CourseworkAssignmentTranslationLanguage")
  ebookUploadTranslations          EbookUploadTranslation[]           @relation("EbookUploadTranslationLanguage")
  phase10Courses                   Phase10Course[]
  phase10CourseTranslations        Phase10CourseTranslation[]
  phase10LessonTranslations        Phase10LessonTranslation[]
  phase10MaterialTranslations      Phase10LessonMaterialTranslation[]

  @@map("languages")
}

model SystemLanguage {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_languages")
}

model SystemSetting {
  id                       String      @id @default(cuid()) @map("_id")
  key                      String      @unique
  systemName               String      @default("ExamFlow Pro")
  systemShortName          String      @default("EMS")
  systemDescription        String?     @default("Professional Online Exam Management System")
  systemLogoUrl            String?
  systemIconUrl            String?
  footerText               String?
  supportEmail             String?
  aiEnabled                Boolean     @default(false)
  aiProvider               AiProvider?
  aiOpenAiApiKey           String?
  aiOpenAiModel            String?
  aiGeminiApiKey           String?
  aiGeminiModel            String?
  aiClaudeApiKey           String?
  aiClaudeModel            String?
  aiTemperature            Float?      @default(0.2)
  smtpHost                 String?
  smtpPort                 Int?
  smtpSecure               Boolean     @default(false)
  smtpUser                 String?
  smtpPass                 String?
  mailFrom                 String?
  requireEmailVerification Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@map("system_settings")
}

model Group {
  id                       String   @id @default(cuid()) @map("_id")
  name                     String
  code                     String   @unique
  academicYearId           String?
  departmentId             String?
  programId                String?
  languageId               String?
  departmentLanguageId     String?
  academicSessionId        String?
  programYearId            String?
  currentProgramSemesterId String?
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  academicYear           AcademicYear?            @relation(fields: [academicYearId], references: [id])
  department             Department?              @relation("AcademicGroupDepartment", fields: [departmentId], references: [id])
  program                AcademicProgram?         @relation(fields: [programId], references: [id])
  language               Language?                @relation("AcademicGroupLanguage", fields: [languageId], references: [id])
  departmentLanguage     DepartmentLanguage?      @relation(fields: [departmentLanguageId], references: [id])
  academicSession        AcademicSession?         @relation(fields: [academicSessionId], references: [id])
  programYear            ProgramYear?             @relation(fields: [programYearId], references: [id])
  currentProgramSemester ProgramSemester?         @relation("ProgramSemesterCurrentGroups", fields: [currentProgramSemesterId], references: [id])
  academicOfferings      AcademicOffering[]
  teacherAssignments     TeacherAssignment[]
  studentSubjects        StudentSubject[]
  exams                  Exam[]
  examScheduleItems      ExamScheduleItem[]
  questions              Question[]
  ebookUploads           EbookUpload[]
  courseworkRules        CourseworkRule[]
  courseworkAssignments  CourseworkAssignment[]
  courseworkTemplates    CourseworkTemplate[]
  courseworkPublications CourseworkPublication[]
  enrollments            StudentEnrollment[]
  historyFromRecords     StudentAcademicHistory[] @relation("HistoryFromGroup")
  historyToRecords       StudentAcademicHistory[] @relation("HistoryToGroup")
  promotionFromRecords   StudentPromotion[]       @relation("PromotionFromGroup")
  promotionToRecords     StudentPromotion[]       @relation("PromotionToGroup")
  transferFromRecords    StudentTransfer[]        @relation("TransferFromGroup")
  transferToRecords      StudentTransfer[]        @relation("TransferToGroup")
  phase9Gradebooks       Phase9Gradebook[]
  phase9ResultRecords    Phase9ResultRecord[]
  phase10Courses         Phase10Course[]

  @@index([academicYearId])
  @@index([departmentId])
  @@index([programId])
  @@index([languageId])
  @@index([departmentLanguageId])
  @@index([academicSessionId])
  @@index([programYearId])
  @@index([currentProgramSemesterId])
  @@map("groups")
}

model AcademicYear {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  year      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups                 Group[]
  teacherAssignments     TeacherAssignment[]
  studentSubjects        StudentSubject[]
  exams                  Exam[]
  examScheduleItems      ExamScheduleItem[]
  questions              Question[]
  ebookUploads           EbookUpload[]
  courseworkRules        CourseworkRule[]
  courseworkAssignments  CourseworkAssignment[]
  courseworkTemplates    CourseworkTemplate[]
  courseworkPublications CourseworkPublication[]
  enrollments            StudentEnrollment[]
  historyFromRecords     StudentAcademicHistory[] @relation("HistoryFromAcademicYear")
  historyToRecords       StudentAcademicHistory[] @relation("HistoryToAcademicYear")

  @@map("academic_years")
}

model Semester {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  number    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherAssignments     TeacherAssignment[]
  studentSubjects        StudentSubject[]
  programSemesters       ProgramSemester[]
  programSubjects        ProgramSubject[]
  academicOfferings      AcademicOffering[]
  exams                  Exam[]
  questions              Question[]
  ebookUploads           EbookUpload[]
  courseworkRules        CourseworkRule[]
  courseworkAssignments  CourseworkAssignment[]
  courseworkTemplates    CourseworkTemplate[]
  courseworkPublications CourseworkPublication[]
  enrollments            StudentEnrollment[]
  historyFromRecords     StudentAcademicHistory[] @relation("HistoryFromSemester")
  historyToRecords       StudentAcademicHistory[] @relation("HistoryToSemester")
  promotionFromRecords   StudentPromotion[]       @relation("PromotionFromSemester")
  promotionToRecords     StudentPromotion[]       @relation("PromotionToSemester")
  transferFromRecords    StudentTransfer[]        @relation("TransferFromSemester")
  transferToRecords      StudentTransfer[]        @relation("TransferToSemester")
  academicCalendars      ExamAcademicCalendar[]
  schedulingSessions     ExamSchedulingSession[]
  examScheduleItems      ExamScheduleItem[]
  workloadEntries        TeacherWorkloadEntry[]
  phase9Gradebooks       Phase9Gradebook[]
  phase9ResultRecords    Phase9ResultRecord[]
  phase10Courses         Phase10Course[]

  @@map("semesters")
}

model TeacherProfile {
  id           String   @id @default(cuid()) @map("_id")
  userId       String   @unique
  departmentId String
  phone        String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                                User                           @relation(fields: [userId], references: [id])
  department                          Department                     @relation(fields: [departmentId], references: [id])
  assignments                         TeacherAssignment[]
  departmentMemberships               TeacherDepartmentMembership[]
  teachingAssignments                 TeachingAssignment[]
  workloadEntries                     TeacherWorkloadEntry[]
  substitutionsFrom                   TeacherSubstitution[]          @relation("TeacherSubstitutionOriginalTeacher")
  substitutionsTo                     TeacherSubstitution[]          @relation("TeacherSubstitutionSubstituteTeacher")
  exams                               Exam[]
  ebookUploads                        EbookUpload[]
  courseworkRules                     CourseworkRule[]
  courseworkAssignments               CourseworkAssignment[]
  courseworkTemplates                 CourseworkTemplate[]
  publishedCourseworkTemplateVersions CourseworkTemplateVersion[]    @relation("CourseworkTemplateVersionPublisher")
  courseworkPublications              CourseworkPublication[]
  lockedCourseworkAttempts            CourseworkAttempt[]            @relation("CourseworkAttemptLocker")
  decidedCourseworkExtensions         CourseworkExtensionRequest[]   @relation("CourseworkExtensionDecider")
  primaryCourseworkGrades             CourseworkGrade[]              @relation("CourseworkPrimaryGrader")
  moderatedCourseworkGrades           CourseworkGrade[]              @relation("CourseworkModerator")
  approvedCourseworkGrades            CourseworkGrade[]              @relation("CourseworkDepartmentApprover")
  courseworkModerationDecisions       CourseworkModerationDecision[] @relation("CourseworkModerationActor")
  courseworkAIReviewAudits            CourseworkAIAudit[]
  examDutyAssignments                 ExamDutyAssignment[]
  invigilatorAssignments              ExamInvigilatorAssignment[]    @relation("ExamInvigilatorTeacher")
  replacementInvigilatorAssignments   ExamInvigilatorAssignment[]    @relation("ExamInvigilatorReplacement")
  phase9OfficerAssignments            Phase9OfficerAssignment[]
  phase9Gradebooks                    Phase9Gradebook[]
  phase9ResultAppeals                 Phase9ResultAppeal[]

  @@index([departmentId])
  @@map("teacher_profiles")
}

model StudentProfile {
  id                   String   @id @default(cuid()) @map("_id")
  userId               String   @unique
  departmentId         String
  phone                String?
  customFieldResponses Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                         User                          @relation(fields: [userId], references: [id])
  department                   Department                    @relation(fields: [departmentId], references: [id])
  subjects                     StudentSubject[]
  examAttempts                 StudentExamAttempt[]
  courseworkAssignments        CourseworkAssignment[]
  courseworkAccessRequests     CourseworkAccessRequest[]
  courseworkSubmissions        CourseworkSubmission[]
  courseworkPublicationTargets CourseworkPublicationTarget[]
  courseworkAttempts           CourseworkAttempt[]
  courseworkAttemptAttachments CourseworkAttemptAttachment[]
  courseworkExtensionRequests  CourseworkExtensionRequest[]
  courseworkGrades             CourseworkGrade[]
  courseworkAttemptRequests    CourseworkAttemptRequest[]
  courseworkAIReviews          CourseworkAIReview[]
  courseworkAISourceMatches    CourseworkAISourceMatch[]
