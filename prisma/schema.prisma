// ExamFlow Pro - Complete Prisma Schema
// MongoDB-compatible, production-ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  TEACHER
  STUDENT
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  RESULT_PUBLISHED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  WRITTEN_ANSWER
  MIXED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  TIMED_OUT
}

enum ResultMode {
  AUTO
  TEACHER_REVIEW
  AI_ASSISTED_OPTIONAL
}

enum ResultStatus {
  PENDING
  PENDING_REVIEW
  REVIEWED
  PUBLISHED
}

enum CourseworkSubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CourseworkAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum AnswerCheckStatus {
  UNCHECKED
  AUTO_CHECKED
  TEACHER_CHECKED
  AI_SUGGESTED
  CONFIRMED
}

enum RegistrationFieldType {
  TEXT
  CHECKBOX
  SELECT
}

model User {
  id            String    @id @default(cuid()) @map("_id")
  email         String    @unique
  password      String
  name          String
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true)
  isEmailVerified Boolean @default(true)
  emailVerificationCode String?
  emailVerificationExpiresAt DateTime?
  passwordResetCode String?
  passwordResetExpiresAt DateTime?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherProfile    TeacherProfile?
  studentProfile    StudentProfile?
  notifications     Notification[]
  activityLogs      ActivityLog[]
  departmentAdminOf Department[]    @relation("DepartmentAdmin")
  resultReviews     ResultReview[]

  @@index([role])
  @@map("users")
}

model Department {
  id          String   @id @default(cuid()) @map("_id")
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  adminId     String?

  admin              User?                @relation("DepartmentAdmin", fields: [adminId], references: [id])
  subjects           Subject[]
  teachers           TeacherProfile[]
  students           StudentProfile[]
  exams              Exam[]
  teacherAssignments TeacherAssignment[]
  registrationFields RegistrationField[]
  ebookUploads       EbookUpload[]
  courseworkRules      CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@map("departments")
}

model Subject {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  code         String   @unique
  description  String?
  departmentId String
  languageId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department         Department          @relation(fields: [departmentId], references: [id])
  language           Language?           @relation(fields: [languageId], references: [id])
  teacherAssignments TeacherAssignment[]
  studentSubjects    StudentSubject[]
  exams              Exam[]
  questions          Question[]
  ebookUploads       EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@index([departmentId])
  @@index([languageId])
  @@map("subjects")
}

model Language {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects           Subject[]
  teacherAssignments TeacherAssignment[]
  studentSubjects    StudentSubject[]
  exams              Exam[]
  questions          Question[]
  ebookUploads       EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@map("languages")
}

model SystemLanguage {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_languages")
}

model SystemSetting {
  id                       String   @id @default(cuid()) @map("_id")
  key                      String   @unique
  systemName               String   @default("ExamFlow Pro")
  systemShortName          String   @default("EMS")
  systemDescription        String?  @default("Professional Online Exam Management System")
  systemLogoUrl            String?
  systemIconUrl            String?
  footerText               String?
  supportEmail             String?
  aiEnabled                Boolean  @default(false)
  aiProvider               AiProvider?
  aiOpenAiApiKey           String?
  aiOpenAiModel            String?
  aiGeminiApiKey           String?
  aiGeminiModel            String?
  aiClaudeApiKey           String?
  aiClaudeModel            String?
  aiTemperature            Float?   @default(0.2)
  smtpHost                 String?
  smtpPort                 Int?
  smtpSecure               Boolean  @default(false)
  smtpUser                 String?
  smtpPass                 String?
  mailFrom                 String?
  requireEmailVerification Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("system_settings")
}

model Group {
  id             String   @id @default(cuid()) @map("_id")
  name           String
  code           String   @unique
  academicYearId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear       AcademicYear       ? @relation(fields: [academicYearId], references: [id])
  teacherAssignments TeacherAssignment[]
  studentSubjects    StudentSubject[]
  exams              Exam[]
  questions          Question[]
  ebookUploads       EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@index([academicYearId])
  @@map("groups")
}

model AcademicYear {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  year      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups             Group[]
  teacherAssignments TeacherAssignment[]
  studentSubjects    StudentSubject[]
  exams              Exam[]
  questions          Question[]
  ebookUploads       EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@map("academic_years")
}

model Semester {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  number    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherAssignments TeacherAssignment[]
  studentSubjects    StudentSubject[]
  exams              Exam[]
  questions          Question[]
  ebookUploads       EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@map("semesters")
}

model TeacherProfile {
  id           String   @id @default(cuid()) @map("_id")
  userId       String   @unique
  departmentId String
  phone        String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  department  Department          @relation(fields: [departmentId], references: [id])
  assignments TeacherAssignment[]
  exams       Exam[]
  ebookUploads EbookUpload[]
  courseworkRules CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@index([departmentId])
  @@map("teacher_profiles")
}

model StudentProfile {
  id           String   @id @default(cuid()) @map("_id")
  userId       String   @unique
  departmentId String
  phone        String?
  customFieldResponses Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  department   Department           @relation(fields: [departmentId], references: [id])
  subjects     StudentSubject[]
  examAttempts StudentExamAttempt[]
  courseworkAssignments CourseworkAssignment[]
  courseworkAccessRequests CourseworkAccessRequest[]
  courseworkSubmissions CourseworkSubmission[]

  @@index([departmentId])
  @@map("student_profiles")
}

model RegistrationField {
  id           String                @id @default(cuid()) @map("_id")
  departmentId String
  label        String
  key          String
  type         RegistrationFieldType
  isRequired   Boolean               @default(false)
  isActive     Boolean               @default(true)
  placeholder  String?
  options      Json?
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, key])
  @@index([departmentId, sortOrder])
  @@map("registration_fields")
}

model TeacherAssignment {
  id             String   @id @default(cuid()) @map("_id")
  teacherId      String
  departmentId   String
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  createdAt      DateTime @default(now())

  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  department   Department     @relation(fields: [departmentId], references: [id])
  subject      Subject        @relation(fields: [subjectId], references: [id])
  language     Language       @relation(fields: [languageId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  semester     Semester       @relation(fields: [semesterId], references: [id])

  @@unique([teacherId, subjectId, languageId, groupId, academicYearId, semesterId])
  @@index([teacherId])
  @@index([departmentId])
  @@map("teacher_assignments")
}

model EbookUpload {
  id             String   @id @default(cuid()) @map("_id")
  teacherId      String
  departmentId   String
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  title          String
  description    String?
  fileName       String
  fileUrl        String
  fileSizeBytes  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  department   Department     @relation(fields: [departmentId], references: [id])
  subject      Subject        @relation(fields: [subjectId], references: [id])
  language     Language       @relation(fields: [languageId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  semester     Semester       @relation(fields: [semesterId], references: [id])

  @@index([teacherId])
  @@index([departmentId, academicYearId, semesterId])
  @@index([subjectId, languageId, groupId, academicYearId, semesterId])
  @@map("ebook_uploads")
}

model CourseworkAssignment {
  id             String   @id @default(cuid()) @map("_id")
  teacherId      String
  studentId      String
  ruleId         String?
  departmentId   String
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  title          String   @default("Coursework and Report Submission")
  rules          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  student      StudentProfile @relation(fields: [studentId], references: [id])
  rule         CourseworkRule? @relation(fields: [ruleId], references: [id])
  department   Department     @relation(fields: [departmentId], references: [id])
  subject      Subject        @relation(fields: [subjectId], references: [id])
  language     Language       @relation(fields: [languageId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  semester     Semester       @relation(fields: [semesterId], references: [id])
  submissions  CourseworkSubmission[]
  accessRequests CourseworkAccessRequest[]

  @@unique([teacherId, studentId, subjectId, languageId, groupId, academicYearId, semesterId])
  @@index([teacherId, academicYearId, semesterId])
  @@index([ruleId])
  @@index([studentId])
  @@map("coursework_assignments")
}

model CourseworkRule {
  id                 String   @id @default(cuid()) @map("_id")
  teacherId          String
  departmentId       String
  subjectId          String
  languageId         String
  groupId            String
  academicYearId     String
  semesterId         String
  rules              String
  useAiValidation    Boolean  @default(false)
  submissionDeadline DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teacher      TeacherProfile         @relation(fields: [teacherId], references: [id])
  department   Department             @relation(fields: [departmentId], references: [id])
  subject      Subject                @relation(fields: [subjectId], references: [id])
  language     Language               @relation(fields: [languageId], references: [id])
  group        Group                  @relation(fields: [groupId], references: [id])
  academicYear AcademicYear           @relation(fields: [academicYearId], references: [id])
  semester     Semester               @relation(fields: [semesterId], references: [id])
  assignments  CourseworkAssignment[]

  @@unique([teacherId, subjectId, languageId, groupId, academicYearId, semesterId])
  @@index([teacherId, academicYearId, semesterId])
  @@index([departmentId])
  @@map("coursework_rules")
}

model CourseworkSubmission {
  id            String                     @id @default(cuid()) @map("_id")
  assignmentId  String
  studentId     String
  fileName      String
  fileUrl       String
  fileSizeBytes Int
  extractedText String?
  status        CourseworkSubmissionStatus @default(PENDING)
  aiFeedback    String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  assignment CourseworkAssignment @relation(fields: [assignmentId], references: [id])
  student    StudentProfile       @relation(fields: [studentId], references: [id])

  @@index([assignmentId, createdAt])
  @@index([studentId, createdAt])
  @@map("coursework_submissions")
}

model CourseworkAccessRequest {
  id                String                        @id @default(cuid()) @map("_id")
  assignmentId      String
  studentId         String
  message           String?
  status            CourseworkAccessRequestStatus @default(PENDING)
  extensionDeadline DateTime?
  teacherNote       String?
  reviewedAt        DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  assignment CourseworkAssignment @relation(fields: [assignmentId], references: [id])
  student    StudentProfile       @relation(fields: [studentId], references: [id])

  @@index([assignmentId, createdAt])
  @@index([studentId, createdAt])
  @@map("coursework_access_requests")
}

model StudentSubject {
  id             String   @id @default(cuid()) @map("_id")
  studentId      String
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  createdAt      DateTime @default(now())

  student      StudentProfile @relation(fields: [studentId], references: [id])
  subject      Subject        @relation(fields: [subjectId], references: [id])
  language     Language       @relation(fields: [languageId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  semester     Semester       @relation(fields: [semesterId], references: [id])

  @@unique([studentId, subjectId, languageId, groupId, academicYearId, semesterId])
  @@index([studentId])
  @@map("student_subjects")
}

model Exam {
  id             String       @id @default(cuid()) @map("_id")
  title          String
  description    String?
  teacherId      String
  departmentId   String
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  questionType   QuestionType @default(MIXED)
  status         ExamStatus   @default(DRAFT)
  resultMode     ResultMode   @default(AUTO)
  totalMarks     Int
  passingMarks   Int
  duration       Int
  startTime      DateTime
  endTime        DateTime
  autoPublish    Boolean      @default(false)
  allowRetake    Boolean      @default(false)
  showAnswers    Boolean      @default(false)
  showMarks      Boolean      @default(true)
  instructions   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  teacher      TeacherProfile      @relation(fields: [teacherId], references: [id])
  department   Department          @relation(fields: [departmentId], references: [id])
  subject      Subject             @relation(fields: [subjectId], references: [id])
  language     Language            @relation(fields: [languageId], references: [id])
  group        Group               @relation(fields: [groupId], references: [id])
  academicYear AcademicYear        @relation(fields: [academicYearId], references: [id])
  semester     Semester            @relation(fields: [semesterId], references: [id])
  questions    ExamQuestion[]
  sessions     ExamSession[]
  attempts     StudentExamAttempt[]
  results      ExamResult[]

  @@index([departmentId, subjectId, languageId, groupId, academicYearId, semesterId, status])
  @@index([teacherId])
  @@index([status])
  @@index([startTime])
  @@map("exams")
}

model Question {
  id             String       @id @default(cuid()) @map("_id")
  subjectId      String
  languageId     String
  groupId        String
  academicYearId String
  semesterId     String
  teacherId      String
  type           QuestionType
  text           String
  imageUrl       String?
  marks          Int          @default(1)
  difficulty     String?
  expectedAnswer String?
  keywords       String?
  explanation    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subject        Subject          @relation(fields: [subjectId], references: [id])
  language       Language         @relation(fields: [languageId], references: [id])
  group          Group            @relation(fields: [groupId], references: [id])
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  semester       Semester         @relation(fields: [semesterId], references: [id])
  options        QuestionOption[]
  examQuestions  ExamQuestion[]
  studentAnswers StudentAnswer[]

  @@index([subjectId, languageId, groupId, academicYearId, semesterId])
  @@index([teacherId])
  @@index([type])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid()) @map("_id")
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  orderIndex Int      @default(0)
  imageUrl   String?
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@map("question_options")
}

model ExamQuestion {
  id         String @id @default(cuid()) @map("_id")
  examId     String
  questionId String
  orderIndex Int    @default(0)
  marks      Int

  exam     Exam     @relation(fields: [examId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@index([examId])
  @@map("exam_questions")
}

model ExamSession {
  id          String   @id @default(cuid()) @map("_id")
  examId      String   @unique
  startedAt   DateTime?
  endedAt     DateTime?
  timerOffset Int      @default(0)
  isPaused    Boolean  @default(false)
  pausedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id])

  @@map("exam_sessions")
}

model StudentExamAttempt {
  id             String        @id @default(cuid()) @map("_id")
  examId         String
  studentId      String
  socketId       String?
  status         AttemptStatus @default(NOT_STARTED)
  startedAt      DateTime?
  submittedAt    DateTime?
  timeSpent      Int?
  ipAddress      String?
  userAgent      String?
  tabSwitchCount Int           @default(0)
  reconnectCount Int           @default(0)
  warningCount   Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  exam    Exam           @relation(fields: [examId], references: [id])
  student StudentProfile @relation(fields: [studentId], references: [id])
  answers StudentAnswer[]
  result  ExamResult?

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@map("student_exam_attempts")
}

model StudentAnswer {
  id                  String            @id @default(cuid()) @map("_id")
  attemptId           String
  questionId          String
  selectedOption      String?
  answerText          String?
  checkStatus         AnswerCheckStatus @default(UNCHECKED)
  isCorrect           Boolean?
  marksAwarded        Float?
  teacherMarks        Float?
  teacherFeedback     String?
  aiSuggestedMarks    Float?
  aiSuggestedFeedback String?
  savedAt             DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  attempt  StudentExamAttempt @relation(fields: [attemptId], references: [id])
  question Question           @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("student_answers")
}

model ExamResult {
  id            String       @id @default(cuid()) @map("_id")
  examId        String
  attemptId     String       @unique
  studentId     String
  totalMarks    Float        @default(0)
  marksObtained Float        @default(0)
  percentage    Float        @default(0)
  grade         String?
  isPassed      Boolean      @default(false)
  status        ResultStatus @default(PENDING)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  exam     Exam               @relation(fields: [examId], references: [id])
  attempt  StudentExamAttempt @relation(fields: [attemptId], references: [id])
  reviews  ResultReview[]

  @@index([examId])
  @@index([studentId])
  @@index([status])
  @@map("exam_results")
}

model ResultReview {
  id         String   @id @default(cuid()) @map("_id")
  resultId   String
  reviewerId String
  notes      String?
  reviewedAt DateTime @default(now())

  result   ExamResult @relation(fields: [resultId], references: [id])
  reviewer User       @relation(fields: [reviewerId], references: [id])

  @@index([resultId])
  @@map("result_reviews")
}

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  title     String
  message   String
  type      String   @default("info")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  action    String
  examId    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([examId])
  @@index([action])
  @@map("activity_logs")
}

model TranslationEntry {
  id        String   @id @default(cuid()) @map("_id")
  locale    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, key])
  @@index([locale])
  @@map("translation_entries")
}
