  examinationEndsAt    DateTime
  makeupStartsAt       DateTime?
  makeupEndsAt         DateTime?
  publishedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  academicSession AcademicSession       @relation(fields: [academicSessionId], references: [id])
  department      Department?           @relation(fields: [departmentId], references: [id])
  semester        Semester?             @relation(fields: [semesterId], references: [id])
  campus          ExamCampus?           @relation(fields: [campusId], references: [id])
  holidays        ExamCalendarHoliday[]

  @@index([academicSessionId, status])
  @@index([departmentId, status])
  @@index([campusId, status])
  @@map("exam_academic_calendars")
}

model ExamCalendarHoliday {
  id                String                 @id @default(cuid()) @map("_id")
  calendarId        String
  departmentId      String?
  campusId          String?
  scopeType         Phase8HolidayScopeType @default(GLOBAL)
  name              String
  startsAt          DateTime
  endsAt            DateTime
  isRecurringAnnual Boolean                @default(false)
  emergencyClosure  Boolean                @default(false)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  calendar   ExamAcademicCalendar @relation(fields: [calendarId], references: [id])
  department Department?          @relation(fields: [departmentId], references: [id])
  campus     ExamCampus?          @relation(fields: [campusId], references: [id])

  @@index([calendarId, startsAt, endsAt])
  @@index([departmentId, startsAt])
  @@index([campusId, startsAt])
  @@map("exam_calendar_holidays")
}

model ExamCampus {
  id           String   @id @default(cuid()) @map("_id")
  departmentId String?
  name         String
  code         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department         Department?             @relation(fields: [departmentId], references: [id])
  calendars          ExamAcademicCalendar[]
  holidays           ExamCalendarHoliday[]
  buildings          ExamBuilding[]
  rooms              ExamRoom[]
  schedulingSessions ExamSchedulingSession[]
  scheduleItems      ExamScheduleItem[]
  dutyAssignments    ExamDutyAssignment[]

  @@index([departmentId, isActive])
  @@map("exam_campuses")
}

model ExamBuilding {
  id        String   @id @default(cuid()) @map("_id")
  campusId  String
  name      String
  code      String
  floors    Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus ExamCampus @relation(fields: [campusId], references: [id])
  rooms  ExamRoom[]

  @@unique([campusId, code])
  @@index([campusId, isActive])
  @@map("exam_buildings")
}

model ExamRoom {
  id               String   @id @default(cuid()) @map("_id")
  campusId         String
  buildingId       String
  name             String
  code             String
  floorNumber      Int      @default(1)
  capacity         Int
  seatLayoutJson   Json?
  equipmentJson    Json?
  isAccessible     Boolean  @default(false)
  isComputerLab    Boolean  @default(false)
  isPracticalLab   Boolean  @default(false)
  hasProjector     Boolean  @default(false)
  hasInternet      Boolean  @default(false)
  isMaintenance    Boolean  @default(false)
  maintenanceNotes String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campus            ExamCampus             @relation(fields: [campusId], references: [id])
  building          ExamBuilding           @relation(fields: [buildingId], references: [id])
  scheduleItems     ExamScheduleItem[]
  seatAssignments   ExamSeatAssignment[]
  attendanceRecords ExamAttendanceRecord[]
  incidents         ExamIncident[]

  @@unique([buildingId, code])
  @@index([campusId, isActive])
  @@index([buildingId, isActive])
  @@map("exam_rooms")
}

model ExamSchedulingSession {
  id                String                        @id @default(cuid()) @map("_id")
  academicSessionId String
  departmentId      String
  programId         String?
  semesterId        String?
  campusId          String?
  name              String
  type              Phase8ScheduleSessionType
  status            Phase8ScheduleLifecycleStatus @default(DRAFT)
  publishedAt       DateTime?
  lockedAt          DateTime?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  academicSession AcademicSession    @relation(fields: [academicSessionId], references: [id])
  department      Department         @relation(fields: [departmentId], references: [id])
  program         AcademicProgram?   @relation(fields: [programId], references: [id])
  semester        Semester?          @relation(fields: [semesterId], references: [id])
  campus          ExamCampus?        @relation(fields: [campusId], references: [id])
  items           ExamScheduleItem[]
  admitCards      ExamAdmitCard[]

  @@index([academicSessionId, status])
  @@index([departmentId, status])
  @@map("exam_scheduling_sessions")
}

model ExamScheduleItem {
  id                  String                        @id @default(cuid()) @map("_id")
  schedulingSessionId String
  examId              String?
  academicOfferingId  String
  departmentId        String
  programId           String
  subjectId           String
  languageId          String
  groupId             String
  academicYearId      String
  semesterId          String
  campusId            String?
  roomId              String?
  status              Phase8ScheduleLifecycleStatus @default(SCHEDULED)
  scheduledStart      DateTime
  scheduledEnd        DateTime
  durationMinutes     Int
  studentCount        Int
  manualOverride      Boolean                       @default(false)
  conflictFlagsJson   Json?
  seatPlanGeneratedAt DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  schedulingSession ExamSchedulingSession       @relation(fields: [schedulingSessionId], references: [id])
  exam              Exam?                       @relation(fields: [examId], references: [id])
  academicOffering  AcademicOffering            @relation(fields: [academicOfferingId], references: [id])
  department        Department                  @relation(fields: [departmentId], references: [id])
  program           AcademicProgram             @relation(fields: [programId], references: [id])
  subject           Subject                     @relation(fields: [subjectId], references: [id])
  language          Language                    @relation(fields: [languageId], references: [id])
  group             Group                       @relation(fields: [groupId], references: [id])
  academicYear      AcademicYear                @relation(fields: [academicYearId], references: [id])
  semester          Semester                    @relation(fields: [semesterId], references: [id])
  campus            ExamCampus?                 @relation(fields: [campusId], references: [id])
  room              ExamRoom?                   @relation(fields: [roomId], references: [id])
  invigilators      ExamInvigilatorAssignment[]
  seatPlan          ExamSeatPlan?
  attendanceRecords ExamAttendanceRecord[]
  incidents         ExamIncident[]

  @@index([schedulingSessionId, status])
  @@index([academicOfferingId, scheduledStart])
  @@index([roomId, scheduledStart, scheduledEnd])
  @@index([campusId, scheduledStart])
  @@map("exam_schedule_items")
}

model ExamSeatPlan {
  id                String   @id @default(cuid()) @map("_id")
  scheduleItemId    String   @unique
  spacingPolicy     Int      @default(1)
  generatedByUserId String?
  generatedAt       DateTime @default(now())
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  scheduleItem    ExamScheduleItem     @relation(fields: [scheduleItemId], references: [id])
  seatAssignments ExamSeatAssignment[]

  @@map("exam_seat_plans")
}

model ExamSeatAssignment {
  id                  String   @id @default(cuid()) @map("_id")
  seatPlanId          String
  roomId              String
  studentId           String
  seatNumber          String
  rowLabel            String?
  columnNumber        Int?
  barcode             String
  qrCode              String
  isAccessibilitySeat Boolean  @default(false)
  isManualOverride    Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  seatPlan          ExamSeatPlan           @relation(fields: [seatPlanId], references: [id])
  room              ExamRoom               @relation(fields: [roomId], references: [id])
  student           StudentProfile         @relation(fields: [studentId], references: [id])
  attendanceRecords ExamAttendanceRecord[]

  @@unique([seatPlanId, seatNumber])
  @@unique([seatPlanId, studentId])
  @@index([roomId, seatNumber])
  @@index([studentId])
  @@map("exam_seat_assignments")
}

model ExamDutyAssignment {
  id           String             @id @default(cuid()) @map("_id")
  teacherId    String
  departmentId String
  campusId     String?
  roleType     Phase8DutyRoleType
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean            @default(true)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  teacher    TeacherProfile @relation(fields: [teacherId], references: [id])
  department Department     @relation(fields: [departmentId], references: [id])
  campus     ExamCampus?    @relation(fields: [campusId], references: [id])

  @@index([teacherId, roleType, isActive])
  @@index([departmentId, roleType, isActive])
  @@map("exam_duty_assignments")
}

model ExamInvigilatorAssignment {
  id                   String                    @id @default(cuid()) @map("_id")
  scheduleItemId       String
  teacherId            String
  replacementTeacherId String?
  roleType             Phase8InvigilatorRoleType
  startsAt             DateTime
  endsAt               DateTime
  notes                String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  scheduleItem       ExamScheduleItem @relation(fields: [scheduleItemId], references: [id])
  teacher            TeacherProfile   @relation("ExamInvigilatorTeacher", fields: [teacherId], references: [id])
  replacementTeacher TeacherProfile?  @relation("ExamInvigilatorReplacement", fields: [replacementTeacherId], references: [id])

  @@unique([scheduleItemId, teacherId, roleType])
  @@index([teacherId, startsAt, endsAt])
  @@index([replacementTeacherId])
  @@map("exam_invigilator_assignments")
}

model ExamAttendanceRecord {
  id               String                 @id @default(cuid()) @map("_id")
  scheduleItemId   String
  studentId        String
  roomId           String?
  seatAssignmentId String?
  markedByUserId   String
  status           Phase8AttendanceStatus
  method           Phase8AttendanceMethod
  markedAt         DateTime               @default(now())
  arrivedAt        DateTime?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  scheduleItem   ExamScheduleItem    @relation(fields: [scheduleItemId], references: [id])
  student        StudentProfile      @relation(fields: [studentId], references: [id])
  room           ExamRoom?           @relation(fields: [roomId], references: [id])
  seatAssignment ExamSeatAssignment? @relation(fields: [seatAssignmentId], references: [id])
  markedBy       User                @relation("ExamAttendanceMarker", fields: [markedByUserId], references: [id])

  @@unique([scheduleItemId, studentId])
  @@index([markedByUserId, markedAt])
  @@index([roomId, markedAt])
  @@map("exam_attendance_records")
}

model ExamAdmitCard {
  id                  String    @id @default(cuid()) @map("_id")
  schedulingSessionId String
  studentId           String
  token               String    @unique
  issuedAt            DateTime  @default(now())
  revokedAt           DateTime?
  lastDownloadedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  schedulingSession ExamSchedulingSession @relation(fields: [schedulingSessionId], references: [id])
  student           StudentProfile        @relation(fields: [studentId], references: [id])

  @@unique([schedulingSessionId, studentId])
  @@index([studentId, issuedAt])
  @@map("exam_admit_cards")
}

model ExamIncident {
  id                   String               @id @default(cuid()) @map("_id")
  scheduleItemId       String
  roomId               String?
  reporterUserId       String
  acknowledgedByUserId String?
  studentId            String?
  type                 Phase8IncidentType
  status               Phase8IncidentStatus @default(OPEN)
  title                String
  description          String
  attachmentUrls       Json?
  acknowledgedAt       DateTime?
  resolvedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  scheduleItem   ExamScheduleItem @relation(fields: [scheduleItemId], references: [id])
  room           ExamRoom?        @relation(fields: [roomId], references: [id])
  reporter       User             @relation("ExamIncidentReporter", fields: [reporterUserId], references: [id])
  acknowledgedBy User?            @relation("ExamIncidentAcknowledger", fields: [acknowledgedByUserId], references: [id])
  student        StudentProfile?  @relation(fields: [studentId], references: [id])

  @@index([scheduleItemId, status, createdAt])
  @@index([studentId, createdAt])
  @@index([reporterUserId, createdAt])
  @@map("exam_incidents")
}

model ActivityLog {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  action    String
  examId    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([examId])
  @@index([action])
  @@map("activity_logs")
}

model TranslationEntry {
  id        String   @id @default(cuid()) @map("_id")
  locale    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, key])
  @@index([locale])
  @@map("translation_entries")
}
