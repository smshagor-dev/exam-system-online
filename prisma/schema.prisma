// ExamFlow Pro - Complete Prisma Schema
// MongoDB-compatible, production-ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  TEACHER
  STUDENT
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  RESULT_PUBLISHED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  WRITTEN_ANSWER
  MIXED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  TIMED_OUT
}

enum ResultMode {
  AUTO
  TEACHER_REVIEW
  AI_ASSISTED_OPTIONAL
}

enum ResultStatus {
  PENDING
  PENDING_REVIEW
  REVIEWED
  PUBLISHED
}

enum CourseworkSubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CourseworkAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum AnswerCheckStatus {
  UNCHECKED
  AUTO_CHECKED
  TEACHER_CHECKED
  AI_SUGGESTED
  CONFIRMED
}

enum RegistrationFieldType {
  TEXT
  CHECKBOX
  SELECT
}

enum AcademicOfferingStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum StudentEnrollmentStatus {
  ACTIVE
  LEAVE
  TRANSFERRED
  GRADUATED
  DROPPED
  ALUMNI
}

enum StudentAcademicHistoryEventType {
  ADMISSION
  ENROLLMENT
  PROMOTION
  GROUP_TRANSFER
  DEPARTMENT_TRANSFER
  PROGRAM_TRANSFER
  ACADEMIC_LEAVE
  READMISSION
  GRADUATION
  ALUMNI
  STATUS_CHANGE
  LEGACY_SYNC
  MANUAL_CORRECTION
}

enum StudentPromotionStatus {
  PROMOTED
  BLOCKED
  OVERRIDDEN
}

enum StudentTransferType {
  GROUP
  DEPARTMENT
  PROGRAM
}

enum StudentLeaveType {
  MEDICAL
  ACADEMIC
  TEMPORARY
  OTHER
}

model User {
  id                         String    @id @default(cuid()) @map("_id")
  email                      String    @unique
  password                   String
  name                       String
  role                       UserRole  @default(STUDENT)
  isActive                   Boolean   @default(true)
  isEmailVerified            Boolean   @default(true)
  emailVerificationCode      String?
  emailVerificationExpiresAt DateTime?
  passwordResetCode          String?
  passwordResetExpiresAt     DateTime?
  avatarUrl                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  teacherProfile         TeacherProfile?
  studentProfile         StudentProfile?
  notifications          Notification[]
  activityLogs           ActivityLog[]
  departmentAdminOf      Department[]             @relation("DepartmentAdmin")
  resultReviews          ResultReview[]
  academicHistoryActions StudentAcademicHistory[]

  @@index([role])
  @@map("users")
}

model Department {
  id          String   @id @default(cuid()) @map("_id")
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  adminId     String?

  admin                 User?                    @relation("DepartmentAdmin", fields: [adminId], references: [id])
  subjects              Subject[]
  teachers              TeacherProfile[]
  students              StudentProfile[]
  academicPrograms      AcademicProgram[]
  departmentLanguages   DepartmentLanguage[]
  academicGroups        Group[]                  @relation("AcademicGroupDepartment")
  academicOfferings     AcademicOffering[]
  exams                 Exam[]
  teacherAssignments    TeacherAssignment[]
  registrationFields    RegistrationField[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]
  enrollments           StudentEnrollment[]
  historyFromRecords    StudentAcademicHistory[] @relation("HistoryFromDepartment")
  historyToRecords      StudentAcademicHistory[] @relation("HistoryToDepartment")
  transferFromRecords   StudentTransfer[]        @relation("TransferFromDepartment")
  transferToRecords     StudentTransfer[]        @relation("TransferToDepartment")

  @@map("departments")
}

model Subject {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  code         String   @unique
  description  String?
  departmentId String
  languageId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department            Department             @relation(fields: [departmentId], references: [id])
  language              Language?              @relation(fields: [languageId], references: [id])
  programSubjects       ProgramSubject[]
  academicOfferings     AcademicOffering[]
  teacherAssignments    TeacherAssignment[]
  studentSubjects       StudentSubject[]
  exams                 Exam[]
  questions             Question[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@index([departmentId])
  @@index([languageId])
  @@map("subjects")
}

model Language {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects              Subject[]
  departmentLanguages   DepartmentLanguage[]
  academicGroups        Group[]                @relation("AcademicGroupLanguage")
  academicOfferings     AcademicOffering[]
  teacherAssignments    TeacherAssignment[]
  studentSubjects       StudentSubject[]
  exams                 Exam[]
  questions             Question[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]
  enrollments           StudentEnrollment[]

  @@map("languages")
}

model SystemLanguage {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_languages")
}

model SystemSetting {
  id                       String      @id @default(cuid()) @map("_id")
  key                      String      @unique
  systemName               String      @default("ExamFlow Pro")
  systemShortName          String      @default("EMS")
  systemDescription        String?     @default("Professional Online Exam Management System")
  systemLogoUrl            String?
  systemIconUrl            String?
  footerText               String?
  supportEmail             String?
  aiEnabled                Boolean     @default(false)
  aiProvider               AiProvider?
  aiOpenAiApiKey           String?
  aiOpenAiModel            String?
  aiGeminiApiKey           String?
  aiGeminiModel            String?
  aiClaudeApiKey           String?
  aiClaudeModel            String?
  aiTemperature            Float?      @default(0.2)
  smtpHost                 String?
  smtpPort                 Int?
  smtpSecure               Boolean     @default(false)
  smtpUser                 String?
  smtpPass                 String?
  mailFrom                 String?
  requireEmailVerification Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@map("system_settings")
}

model Group {
  id                       String   @id @default(cuid()) @map("_id")
  name                     String
  code                     String   @unique
  academicYearId           String?
  departmentId             String?
  programId                String?
  languageId               String?
  departmentLanguageId     String?
  academicSessionId        String?
  programYearId            String?
  currentProgramSemesterId String?
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  academicYear           AcademicYear?            @relation(fields: [academicYearId], references: [id])
  department             Department?              @relation("AcademicGroupDepartment", fields: [departmentId], references: [id])
  program                AcademicProgram?         @relation(fields: [programId], references: [id])
  language               Language?                @relation("AcademicGroupLanguage", fields: [languageId], references: [id])
  departmentLanguage     DepartmentLanguage?      @relation(fields: [departmentLanguageId], references: [id])
  academicSession        AcademicSession?         @relation(fields: [academicSessionId], references: [id])
  programYear            ProgramYear?             @relation(fields: [programYearId], references: [id])
  currentProgramSemester ProgramSemester?         @relation("ProgramSemesterCurrentGroups", fields: [currentProgramSemesterId], references: [id])
  academicOfferings      AcademicOffering[]
  teacherAssignments     TeacherAssignment[]
  studentSubjects        StudentSubject[]
  exams                  Exam[]
  questions              Question[]
  ebookUploads           EbookUpload[]
  courseworkRules        CourseworkRule[]
  courseworkAssignments  CourseworkAssignment[]
  enrollments            StudentEnrollment[]
  historyFromRecords     StudentAcademicHistory[] @relation("HistoryFromGroup")
  historyToRecords       StudentAcademicHistory[] @relation("HistoryToGroup")
  promotionFromRecords   StudentPromotion[]       @relation("PromotionFromGroup")
  promotionToRecords     StudentPromotion[]       @relation("PromotionToGroup")
  transferFromRecords    StudentTransfer[]        @relation("TransferFromGroup")
  transferToRecords      StudentTransfer[]        @relation("TransferToGroup")

  @@index([academicYearId])
  @@index([departmentId])
  @@index([programId])
  @@index([languageId])
  @@index([departmentLanguageId])
  @@index([academicSessionId])
  @@index([programYearId])
  @@index([currentProgramSemesterId])
  @@map("groups")
}

model AcademicYear {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  year      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups                Group[]
  teacherAssignments    TeacherAssignment[]
  studentSubjects       StudentSubject[]
  exams                 Exam[]
  questions             Question[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]
  enrollments           StudentEnrollment[]
  historyFromRecords    StudentAcademicHistory[] @relation("HistoryFromAcademicYear")
  historyToRecords      StudentAcademicHistory[] @relation("HistoryToAcademicYear")

  @@map("academic_years")
}

model Semester {
  id        String   @id @default(cuid()) @map("_id")
  name      String   @unique
  number    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherAssignments    TeacherAssignment[]
  studentSubjects       StudentSubject[]
  programSemesters      ProgramSemester[]
  programSubjects       ProgramSubject[]
  academicOfferings     AcademicOffering[]
  exams                 Exam[]
  questions             Question[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]
  enrollments           StudentEnrollment[]
  historyFromRecords    StudentAcademicHistory[] @relation("HistoryFromSemester")
  historyToRecords      StudentAcademicHistory[] @relation("HistoryToSemester")
  promotionFromRecords  StudentPromotion[]       @relation("PromotionFromSemester")
  promotionToRecords    StudentPromotion[]       @relation("PromotionToSemester")
  transferFromRecords   StudentTransfer[]        @relation("TransferFromSemester")
  transferToRecords     StudentTransfer[]        @relation("TransferToSemester")

  @@map("semesters")
}

model TeacherProfile {
  id           String   @id @default(cuid()) @map("_id")
  userId       String   @unique
  departmentId String
  phone        String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id])
  department            Department             @relation(fields: [departmentId], references: [id])
  assignments           TeacherAssignment[]
  exams                 Exam[]
  ebookUploads          EbookUpload[]
  courseworkRules       CourseworkRule[]
  courseworkAssignments CourseworkAssignment[]

  @@index([departmentId])
  @@map("teacher_profiles")
}

model StudentProfile {
  id                   String   @id @default(cuid()) @map("_id")
  userId               String   @unique
  departmentId         String
  phone                String?
  customFieldResponses Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                     User                      @relation(fields: [userId], references: [id])
  department               Department                @relation(fields: [departmentId], references: [id])
  subjects                 StudentSubject[]
  examAttempts             StudentExamAttempt[]
  courseworkAssignments    CourseworkAssignment[]
  courseworkAccessRequests CourseworkAccessRequest[]
  courseworkSubmissions    CourseworkSubmission[]
  enrollments              StudentEnrollment[]
  academicHistory          StudentAcademicHistory[]
  promotionRecords         StudentPromotion[]
  transferRecords          StudentTransfer[]
  leaveRecords             StudentLeave[]
  graduationRecords        StudentGraduation[]

  @@index([departmentId])
  @@map("student_profiles")
}

model StudentEnrollment {
  id                   String                  @id @default(cuid()) @map("_id")
  studentId            String
  departmentId         String
  academicYearId       String?
  academicSessionId    String
  programId            String
  programYearId        String
  semesterId           String
  programSemesterId    String?
  groupId              String
  departmentLanguageId String?
  languageId           String?
  status               StudentEnrollmentStatus @default(ACTIVE)
  enrolledAt           DateTime                @default(now())
  endedAt              DateTime?
  graduationDate       DateTime?
  isActive             Boolean                 @default(true)
  notes                String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  student            StudentProfile           @relation(fields: [studentId], references: [id])
  department         Department               @relation(fields: [departmentId], references: [id])
  academicYear       AcademicYear?            @relation(fields: [academicYearId], references: [id])
  academicSession    AcademicSession          @relation(fields: [academicSessionId], references: [id])
  program            AcademicProgram          @relation(fields: [programId], references: [id])
  programYear        ProgramYear              @relation(fields: [programYearId], references: [id])
  semester           Semester                 @relation(fields: [semesterId], references: [id])
  programSemester    ProgramSemester?         @relation(fields: [programSemesterId], references: [id])
  group              Group                    @relation(fields: [groupId], references: [id])
  departmentLanguage DepartmentLanguage?      @relation(fields: [departmentLanguageId], references: [id])
  language           Language?                @relation(fields: [languageId], references: [id])
  historyEntries     StudentAcademicHistory[]
  promotionsFrom     StudentPromotion[]       @relation("PromotionFromEnrollment")
  promotionsTo       StudentPromotion[]       @relation("PromotionToEnrollment")
  transfersFrom      StudentTransfer[]        @relation("TransferFromEnrollment")
  transfersTo        StudentTransfer[]        @relation("TransferToEnrollment")
  leaves             StudentLeave[]
  graduationRecords  StudentGraduation[]

  @@index([studentId, status, isActive])
  @@index([departmentId, academicSessionId])
  @@index([programId, programYearId, semesterId])
  @@index([groupId])
  @@map("student_enrollments")
}

model StudentAcademicHistory {
  id                    String                          @id @default(cuid()) @map("_id")
  studentId             String
  enrollmentId          String?
  actorUserId           String?
  eventType             StudentAcademicHistoryEventType
  fromDepartmentId      String?
  toDepartmentId        String?
  fromAcademicYearId    String?
  toAcademicYearId      String?
  fromAcademicSessionId String?
  toAcademicSessionId   String?
  fromProgramId         String?
  toProgramId           String?
  fromProgramYearId     String?
  toProgramYearId       String?
  fromSemesterId        String?
  toSemesterId          String?
  fromProgramSemesterId String?
  toProgramSemesterId   String?
  fromGroupId           String?
  toGroupId             String?
  fromStatus            StudentEnrollmentStatus?
  toStatus              StudentEnrollmentStatus?
  reason                String?
  notes                 String?
  occurredAt            DateTime                        @default(now())
  createdAt             DateTime                        @default(now())

  student             StudentProfile     @relation(fields: [studentId], references: [id])
  enrollment          StudentEnrollment? @relation(fields: [enrollmentId], references: [id])
  actor               User?              @relation(fields: [actorUserId], references: [id])
  fromDepartment      Department?        @relation("HistoryFromDepartment", fields: [fromDepartmentId], references: [id])
  toDepartment        Department?        @relation("HistoryToDepartment", fields: [toDepartmentId], references: [id])
  fromAcademicYear    AcademicYear?      @relation("HistoryFromAcademicYear", fields: [fromAcademicYearId], references: [id])
  toAcademicYear      AcademicYear?      @relation("HistoryToAcademicYear", fields: [toAcademicYearId], references: [id])
  fromAcademicSession AcademicSession?   @relation("HistoryFromAcademicSession", fields: [fromAcademicSessionId], references: [id])
  toAcademicSession   AcademicSession?   @relation("HistoryToAcademicSession", fields: [toAcademicSessionId], references: [id])
  fromProgram         AcademicProgram?   @relation("HistoryFromProgram", fields: [fromProgramId], references: [id])
  toProgram           AcademicProgram?   @relation("HistoryToProgram", fields: [toProgramId], references: [id])
  fromProgramYear     ProgramYear?       @relation("HistoryFromProgramYear", fields: [fromProgramYearId], references: [id])
  toProgramYear       ProgramYear?       @relation("HistoryToProgramYear", fields: [toProgramYearId], references: [id])
  fromSemester        Semester?          @relation("HistoryFromSemester", fields: [fromSemesterId], references: [id])
  toSemester          Semester?          @relation("HistoryToSemester", fields: [toSemesterId], references: [id])
  fromProgramSemester ProgramSemester?   @relation("HistoryFromProgramSemester", fields: [fromProgramSemesterId], references: [id])
  toProgramSemester   ProgramSemester?   @relation("HistoryToProgramSemester", fields: [toProgramSemesterId], references: [id])
  fromGroup           Group?             @relation("HistoryFromGroup", fields: [fromGroupId], references: [id])
  toGroup             Group?             @relation("HistoryToGroup", fields: [toGroupId], references: [id])

  @@index([studentId, occurredAt])
  @@index([enrollmentId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("student_academic_history")
}

model StudentPromotion {
  id                       String                 @id @default(cuid()) @map("_id")
  studentId                String
  fromEnrollmentId         String
  toEnrollmentId           String?
  fromAcademicSessionId    String
  toAcademicSessionId      String
  fromProgramId            String
  toProgramId              String
  fromProgramYearId        String
  toProgramYearId          String
  fromSemesterId           String
  toSemesterId             String
  fromProgramSemesterId    String?
  toProgramSemesterId      String?
  fromGroupId              String
  toGroupId                String
  status                   StudentPromotionStatus @default(PROMOTED)
  manualOverride           Boolean                @default(false)
  overrideReason           String?
  curriculumValidated      Boolean                @default(false)
  resultPublishedValidated Boolean                @default(false)
  promotedAt               DateTime               @default(now())
  notes                    String?
  createdAt                DateTime               @default(now())

  student             StudentProfile     @relation(fields: [studentId], references: [id])
  fromEnrollment      StudentEnrollment  @relation("PromotionFromEnrollment", fields: [fromEnrollmentId], references: [id])
  toEnrollment        StudentEnrollment? @relation("PromotionToEnrollment", fields: [toEnrollmentId], references: [id])
  fromAcademicSession AcademicSession    @relation("PromotionFromAcademicSession", fields: [fromAcademicSessionId], references: [id])
  toAcademicSession   AcademicSession    @relation("PromotionToAcademicSession", fields: [toAcademicSessionId], references: [id])
  fromProgram         AcademicProgram    @relation("PromotionFromProgram", fields: [fromProgramId], references: [id])
  toProgram           AcademicProgram    @relation("PromotionToProgram", fields: [toProgramId], references: [id])
  fromProgramYear     ProgramYear        @relation("PromotionFromProgramYear", fields: [fromProgramYearId], references: [id])
  toProgramYear       ProgramYear        @relation("PromotionToProgramYear", fields: [toProgramYearId], references: [id])
  fromSemester        Semester           @relation("PromotionFromSemester", fields: [fromSemesterId], references: [id])
  toSemester          Semester           @relation("PromotionToSemester", fields: [toSemesterId], references: [id])
  fromProgramSemester ProgramSemester?   @relation("PromotionFromProgramSemester", fields: [fromProgramSemesterId], references: [id])
  toProgramSemester   ProgramSemester?   @relation("PromotionToProgramSemester", fields: [toProgramSemesterId], references: [id])
  fromGroup           Group              @relation("PromotionFromGroup", fields: [fromGroupId], references: [id])
  toGroup             Group              @relation("PromotionToGroup", fields: [toGroupId], references: [id])

  @@index([studentId, promotedAt])
  @@index([fromEnrollmentId])
  @@index([toEnrollmentId])
  @@map("student_promotions")
}

model StudentTransfer {
  id                    String              @id @default(cuid()) @map("_id")
  studentId             String
  fromEnrollmentId      String
  toEnrollmentId        String?
  transferType          StudentTransferType
  fromDepartmentId      String
  toDepartmentId        String
  fromAcademicSessionId String
  toAcademicSessionId   String
  fromProgramId         String
  toProgramId           String
  fromProgramYearId     String
  toProgramYearId       String
  fromSemesterId        String
  toSemesterId          String
  fromProgramSemesterId String?
  toProgramSemesterId   String?
  fromGroupId           String
  toGroupId             String
  transferredAt         DateTime            @default(now())
  reason                String?
  notes                 String?
  createdAt             DateTime            @default(now())

  student             StudentProfile     @relation(fields: [studentId], references: [id])
  fromEnrollment      StudentEnrollment  @relation("TransferFromEnrollment", fields: [fromEnrollmentId], references: [id])
  toEnrollment        StudentEnrollment? @relation("TransferToEnrollment", fields: [toEnrollmentId], references: [id])
  fromDepartment      Department         @relation("TransferFromDepartment", fields: [fromDepartmentId], references: [id])
  toDepartment        Department         @relation("TransferToDepartment", fields: [toDepartmentId], references: [id])
  fromAcademicSession AcademicSession    @relation("TransferFromAcademicSession", fields: [fromAcademicSessionId], references: [id])
  toAcademicSession   AcademicSession    @relation("TransferToAcademicSession", fields: [toAcademicSessionId], references: [id])
  fromProgram         AcademicProgram    @relation("TransferFromProgram", fields: [fromProgramId], references: [id])
  toProgram           AcademicProgram    @relation("TransferToProgram", fields: [toProgramId], references: [id])
  fromProgramYear     ProgramYear        @relation("TransferFromProgramYear", fields: [fromProgramYearId], references: [id])
  toProgramYear       ProgramYear        @relation("TransferToProgramYear", fields: [toProgramYearId], references: [id])
  fromSemester        Semester           @relation("TransferFromSemester", fields: [fromSemesterId], references: [id])
  toSemester          Semester           @relation("TransferToSemester", fields: [toSemesterId], references: [id])
  fromProgramSemester ProgramSemester?   @relation("TransferFromProgramSemester", fields: [fromProgramSemesterId], references: [id])
  toProgramSemester   ProgramSemester?   @relation("TransferToProgramSemester", fields: [toProgramSemesterId], references: [id])
  fromGroup           Group              @relation("TransferFromGroup", fields: [fromGroupId], references: [id])
  toGroup             Group              @relation("TransferToGroup", fields: [toGroupId], references: [id])

  @@index([studentId, transferredAt])
  @@index([transferType, transferredAt])
  @@map("student_transfers")
}

model StudentLeave {
  id           String           @id @default(cuid()) @map("_id")
  studentId    String
  enrollmentId String
  leaveType    StudentLeaveType
  startsAt     DateTime
  endsAt       DateTime?
  status       String           @default("APPROVED")
  reason       String?
  notes        String?
  approvedAt   DateTime         @default(now())
  readmittedAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  student    StudentProfile    @relation(fields: [studentId], references: [id])
  enrollment StudentEnrollment @relation(fields: [enrollmentId], references: [id])

  @@index([studentId, approvedAt])
  @@index([enrollmentId])
  @@map("student_leaves")
}

model StudentGraduation {
  id                   String    @id @default(cuid()) @map("_id")
  studentId            String
  enrollmentId         String
  graduatedAt          DateTime
  finalCgpa            Float?
  degreeClassification String?
  certificateNumber    String?
  degreeAwarded        String
  alumniAt             DateTime?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  student    StudentProfile    @relation(fields: [studentId], references: [id])
  enrollment StudentEnrollment @relation(fields: [enrollmentId], references: [id])

  @@unique([certificateNumber])
  @@index([studentId, graduatedAt])
  @@index([enrollmentId])
  @@map("student_graduations")
}

model RegistrationField {
  id           String                @id @default(cuid()) @map("_id")
  departmentId String
  label        String
  key          String
  type         RegistrationFieldType
  isRequired   Boolean               @default(false)
  isActive     Boolean               @default(true)
  placeholder  String?
  options      Json?
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, key])
  @@index([departmentId, sortOrder])
  @@map("registration_fields")
}

model TeacherAssignment {
  id                 String   @id @default(cuid()) @map("_id")
  teacherId          String
  departmentId       String
  subjectId          String
  languageId         String
  groupId            String
  academicYearId     String
  semesterId         String
  academicOfferingId String?
  createdAt          DateTime @default(now())

  teacher          TeacherProfile    @relation(fields: [teacherId], references: [id])
  department       Department        @relation(fields: [departmentId], references: [id])
  subject          Subject           @relation(fields: [subjectId], references: [id])
  language         Language          @relation(fields: [languageId], references: [id])
  group            Group             @relation(fields: [groupId], references: [id])
  academicYear     AcademicYear      @relation(fields: [academicYearId], references: [id])
  semester         Semester          @relation(fields: [semesterId], references: [id])
  academicOffering AcademicOffering? @relation(fields: [academicOfferingId], references: [id])

