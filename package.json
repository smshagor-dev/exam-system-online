{
  "name": "examflow-pro",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\" && next build --webpack",
    "start": "node -e \"process.env.NODE_ENV='production'; require('./server.js')\"",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "phase2:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-2/targeted-tests.ts",
    "phase2:reconcile-legacy": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-2/reconcile-legacy-academic-context.ts",
    "phase2:backfill:dry": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-2/backfill-academic-architecture.ts --dry-run",
    "phase2:backfill": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-2/backfill-academic-architecture.ts --apply",
    "phase2:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-2/verify-academic-architecture.ts",
    "phase2:qa": "npm run phase2:test && npm run phase2:verify && npm run typecheck && npm run lint && npm run build",
    "phase3:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-3/lifecycle-tests.ts",
    "phase3:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-3/verify-student-lifecycle.ts",
    "phase3:auth": "node scripts/phase-3/authorization-matrix.mjs",
    "phase3:qa": "npm run phase3:test && npm run phase3:verify && npm run typecheck && npm run lint && npm run build",
    "phase4:backfill:dry": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-4/backfill-teacher-assignments.ts --dry-run",
    "phase4:backfill": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-4/backfill-teacher-assignments.ts --apply",
    "phase4:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-4/teacher-architecture-tests.ts",
    "phase4:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-4/verify-teacher-architecture.ts",
    "phase4:auth": "node scripts/phase-4/authorization-matrix.mjs",
    "phase4:qa": "npm run phase4:test && npm run phase4:verify && npm run phase4:auth && npm run typecheck && npm run lint && npm run build",
