    "phase5:backfill": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-5/backfill-multilingual-content.ts --apply",
    "phase5:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-5/multilingual-content-tests.ts",
    "phase5:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-5/verify-multilingual-content.ts",
    "phase5:auth": "node scripts/phase-5/authorization-matrix.mjs",
    "phase5:qa": "npm run phase5:test && npm run phase5:verify && npm run phase5:auth && npm run typecheck && npm run lint && npm run build",
    "phase6:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-6/runtime-tests.ts && ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-6/submit-path-tests.ts",
    "phase6:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-6/verify-exam-engine.ts",
    "phase6:auth": "node scripts/phase-6/authorization-matrix.mjs",
    "phase6:qa": "npm run phase6:test && npm run phase6:verify && npm run phase6:auth && npm run typecheck && npm run lint && npm run build",
    "phase7:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-7/coursework-platform-tests.ts",
    "phase7:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-7/verify-coursework-platform.ts",
    "phase7:auth": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-7/authorization-matrix.ts",
    "phase7:qa": "npm run phase7:test && npm run phase7:verify && npm run phase7:auth && npm run typecheck && npm run lint && npm run build",
    "phase7.5:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-7-5/verify-ai-reviews.ts",
    "phase7.5:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-7-5/verify-ai-reviews.ts",
    "phase7.5:auth": "node scripts/phase-7-5/authorization-matrix.mjs",
    "phase7.5:browser-smoke": "node scripts/phase-7-5/browser-smoke.mjs",
    "phase7.5:qa": "npm run phase7.5:test && npm run phase7.5:verify && npm run phase7.5:auth && npm run typecheck && npm run lint && npm run build",
    "phase8:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-8/platform-tests.ts",
    "phase8:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-8/verify-scheduling-platform.ts",
    "phase8:auth": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-8/authorization-matrix.ts",
    "phase8:qa": "npm run phase8:test && npm run phase8:verify && npm run phase8:auth && npm run typecheck && npm run lint && npm run build",
    "phase9:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-9/platform-tests.ts",
    "phase9:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-9/verify-results-platform.ts",
    "phase9:auth": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-9/authorization-matrix.ts",
    "phase9:browser-smoke": "node scripts/phase-9/browser-smoke.mjs",
    "phase9:qa": "npm run phase9:test && npm run phase9:verify && npm run phase9:auth && npm run typecheck && npm run lint && npm run build",
    "phase10:test": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-10/platform-tests.ts",
    "phase10:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-10/verify-lms-platform.ts",
    "phase10:auth": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/phase-10/authorization-matrix.ts",
    "phase10:browser-smoke": "node scripts/phase-10/browser-smoke.mjs",
    "phase10:qa": "npm run phase10:test && npm run phase10:verify && npm run phase10:auth && npm run typecheck && npm run lint && npm run build",
    "qa": "npm run typecheck && npm run lint && npm run build",
    "prod:check": "npm run qa",
    "production:academic-cleanup:dry": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/cleanup-demo-academic-data.ts --dry-run",
    "production:academic-cleanup": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/cleanup-demo-academic-data.ts --apply",
    "production:bootstrap-admin": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/bootstrap-release-verification.ts --mode=bootstrap-admin",
    "production:clean-install:verify": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/verify-clean-install.ts",
    "production:verify-mail": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/verify-mail-transport.ts",
    "production:verify-socket": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json scripts/production/verify-socket-runtime.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma db push",
    "db:seed": "ts-node -r tsconfig-paths/register --transpile-only --project tsconfig.seed.json prisma/seed-production.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
