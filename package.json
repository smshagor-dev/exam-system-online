  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/smtp-server": "^3.5.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "playwright": "^1.61.1",
    "postcss": "8.5.19",
    "prisma": "^5.22.0",
    "redis-memory-server": "^0.17.0",
    "smtp-server": "^3.19.2",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed-production.ts"
  },
  "overrides": {
    "ws": "8.21.0"
  }
