    "lucide-react": "^0.454.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "9.0.3",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.53.2",
    "redis": "^6.1.0",
    "socket.io": "^4.8.1",
