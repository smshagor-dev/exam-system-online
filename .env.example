# ExamFlow Pro Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL="mysql://root:password@localhost:3306/examflow_pro"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Socket.IO ─────────────────────────────────────────────────────────────────
# Public URL used by socket client (defaults to window.location.origin)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# ─── AI Evaluation ─────────────────────────────────────────────────────────────
# Set to "true" to enable AI-assisted answer checking
AI_EVALUATION_ENABLED="false"

# OpenAI API key (only needed if AI_EVALUATION_ENABLED=true)
# OPENAI_API_KEY="sk-..."

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=localhost
NODE_ENV=development
