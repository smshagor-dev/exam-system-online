# ExamFlow Pro Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string
DATABASE_URL="mongodb+srv://username:password@cluster0.example.mongodb.net/examflow_pro?retryWrites=true&w=majority&appName=Cluster0"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-the-same-random-64-plus-char-secret"
NEXTAUTH_SECRET="replace-with-the-same-random-64-plus-char-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Socket.IO ─────────────────────────────────────────────────────────────────
# Public URL used by socket client (defaults to window.location.origin)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Redis-backed Phase 6 runtime
# Set REDIS_REQUIRED=true in production to fail fast if Redis is unavailable.
# Leave ALLOW_MEMORY_RUNTIME_FALLBACK=false when you need strict distributed runtime behavior.
# REDIS_URL="redis://127.0.0.1:6379"
# REDIS_REQUIRED="true"
# ALLOW_MEMORY_RUNTIME_FALLBACK="false"
# REDIS_CONNECT_TIMEOUT_MS="15000"

# ─── AI Evaluation ─────────────────────────────────────────────────────────────
# AI provider settings are managed from the database via Admin/Teacher AI Settings.

# Email delivery fallback for verification and password reset codes (optional)
# Admin SMTP Setup stored in the database takes priority over these values.
# If everything is omitted, codes will still work in development via debug responses/logs.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# MAIL_FROM="ExamFlow Pro <no-reply@example.com>"

# ─── Server ────────────────────────────────────────────────────────────────────
#
# Academic year promotion job
# Students are promoted once per year on September 1 in this timezone.
# BSc students stop at Year 4, MSc students stop at Year 2, and then student login is blocked.
# ACADEMIC_PROMOTION_TIMEZONE="Asia/Dhaka"
PORT=3000
HOST=localhost
NODE_ENV=development
AUTO_DB_PUSH=false
